# Runtime
NODE_ENV=development
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:4174
LOG_LEVEL=info

# Data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/getswyft
REDIS_URL=redis://localhost:6379

# Auth
AUTH_PROVIDER=keycloak
AUTH_ISSUER_URL=https://keycloak.example.com/realms/getswyft
AUTH_AUDIENCE=
AUTH_JWKS_URI=
DEV_AUTH_BYPASS=true
DEV_DEFAULT_TENANT_SLUG=default

# Storage
STORAGE_PROVIDER=local
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Voice/Video foundation
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
