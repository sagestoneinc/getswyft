# Runtime
NODE_ENV=development
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:4174
LOG_LEVEL=info

# Data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/getswyft
REDIS_URL=redis://localhost:6379

# Auth
AUTH_PROVIDER=supabase
AUTH_ISSUER_URL=
AUTH_AUDIENCE=
AUTH_JWKS_URI=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_DB_URL=
DEV_AUTH_BYPASS=true
DEV_DEFAULT_TENANT_SLUG=default
APP_BASE_URL=http://localhost:5173

# Email
EMAIL_PROVIDER=log
EMAIL_FROM=Getswyft <onboarding@example.com>
EMAIL_REPLY_TO=
RESEND_API_KEY=

# Storage
STORAGE_PROVIDER=local
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Voice/Video foundation
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Push delivery
PUSH_PROVIDER=log
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Telephony
TELEPHONY_PROVIDER=log
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=
