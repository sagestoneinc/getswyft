# Runtime
NODE_ENV=development
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:4174
LOG_LEVEL=info

# Data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/getswyft
REDIS_URL=redis://localhost:6379

# Auth
AUTH_PROVIDER=supabase
AUTH_ISSUER_URL=
AUTH_AUDIENCE=
AUTH_JWKS_URI=
SUPABASE_URL=https://your-project.supabase.co
JWT_SECRET=replace-with-a-long-random-secret
SUPABASE_DB_URL=
SUPABASE_DB_FORCE_IPV4=true
SUPABASE_DB_URL_IPV4=
DEV_AUTH_BYPASS=true
DEV_DEFAULT_TENANT_SLUG=default
APP_BASE_URL=http://localhost:5173

# Email
EMAIL_PROVIDER=log
EMAIL_FROM=Getswyft <onboarding@example.com>
EMAIL_REPLY_TO=
RESEND_API_KEY=

# Storage
STORAGE_PROVIDER=local
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Voice/Video foundation
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Push delivery
PUSH_PROVIDER=log
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Telephony
TELEPHONY_PROVIDER=log
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=

# Billing (Paddle)
BILLING_PROVIDER=manual
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=sandbox
PADDLE_PRICE_ID=

# AI runtime
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_HTTP_TIMEOUT_MS=30000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=120
RATE_LIMIT_WIDGET_MAX=30
