generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum PresenceStatus {
  ONLINE
  AWAY
  BUSY
  OFFLINE
}

enum ModerationStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum RoutingMode {
  MANUAL
  FIRST_AVAILABLE
  ROUND_ROBIN
}

enum MessageSenderType {
  VISITOR
  AGENT
  SYSTEM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum WebhookEndpointStatus {
  ACTIVE
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum BillingSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

enum NotificationDeviceProvider {
  FCM
}

enum NotificationDevicePlatform {
  WEB
}

model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  domains           TenantDomain[]
  branding          TenantBranding?
  featureFlags      TenantFeatureFlag[]
  routingSettings   TenantRoutingSettings?
  userRoles         UserRole[]
  presenceSessions  PresenceSession[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  analyticsEvents   AnalyticsEvent[]
  aiConfigs         AIConfig[]
  moderationReports ModerationReport[]
  conversations     Conversation[]
  invitations       TenantInvitation[]
  apiKeys           TenantApiKey[]
  webhookEndpoints  WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  billingSubscription BillingSubscription?
  billingInvoices   BillingInvoice[]
  notificationDevices NotificationDevice[]
  channels          Channel[]
  callSessions      CallSession[]
  posts             Post[]
  complianceExports ComplianceExport[]
  aiInteractions    AIInteraction[]
}

model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String
  domain    String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantBranding {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  primaryColor String?
  logoUrl      String?
  supportEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantFeatureFlag {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  enabled   Boolean  @default(false)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, createdAt])
}

model TenantRoutingSettings {
  id                 String      @id @default(cuid())
  tenantId           String      @unique
  routingMode        RoutingMode @default(ROUND_ROBIN)
  officeHoursEnabled Boolean     @default(true)
  timezone           String      @default("America/Chicago")
  officeHoursStart   String      @default("09:00")
  officeHoursEnd     String      @default("18:00")
  fallbackUserId     String?
  afterHoursMessage  String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fallbackUser User?  @relation("RoutingFallbackUser", fields: [fallbackUserId], references: [id], onDelete: SetNull)
}

model User {
  id             String   @id @default(cuid())
  externalAuthId String   @unique
  email          String
  displayName    String?
  avatarUrl      String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile               Profile?
  userRoles             UserRole[]
  notifications         Notification[]
  presenceSessions      PresenceSession[]
  auditLogs             AuditLog[]            @relation("ActorAuditLogs")
  analyticsEvents       AnalyticsEvent[]
  moderationReports     ModerationReport[]    @relation("ReporterModerationReports")
  assignedConversations Conversation[]        @relation("AssignedConversations")
  conversationMessages  ConversationMessage[] @relation("MessageSender")
  messageReactions      MessageReaction[]
  messageReceipts       MessageReceipt[]
  sentInvitations       TenantInvitation[]    @relation("SentInvitations")
  acceptedInvitations   TenantInvitation[]    @relation("AcceptedInvitations")
  createdTenantApiKeys  TenantApiKey[]        @relation("CreatedTenantApiKeys")
  routingFallbackTenants TenantRoutingSettings[] @relation("RoutingFallbackUser")
  notificationDevices   NotificationDevice[]
  channelMemberships       ChannelMember[]
  channelMessages          ChannelMessage[]          @relation("ChannelMessageSender")
  channelMessageReactions  ChannelMessageReaction[]
  initiatedCalls           CallSession[]             @relation("InitiatedCalls")
  callParticipations       CallParticipant[]
  callTelemetry            CallTelemetry[]
  posts                    Post[]                    @relation("PostAuthor")
  postComments             PostComment[]             @relation("CommentAuthor")
  postReactions            PostReaction[]
  createdChannels          Channel[]                 @relation("ChannelCreator")
  complianceExports        ComplianceExport[]        @relation("ComplianceRequester")
  aiInteractions           AIInteraction[]
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  timezone  String?
  locale    String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]
  invitations TenantInvitation[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, createdAt])
  @@index([userId])
}

model PresenceSession {
  id           String         @id @default(cuid())
  tenantId     String
  userId       String
  connectionId String
  status       PresenceStatus @default(ONLINE)
  lastSeenAt   DateTime       @default(now())
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, connectionId])
  @@index([tenantId, lastSeenAt])
}

model Conversation {
  id                 String             @id @default(cuid())
  tenantId           String
  assignedUserId     String?
  status             ConversationStatus @default(OPEN)
  leadName           String
  leadEmail          String?
  leadPhone          String?
  leadSource         String?
  leadUtm            String?
  listingAddress     String
  listingPrice       String
  listingBeds        Int?
  listingBaths       Int?
  listingSqft        Int?
  listingMls         String?
  lastMessagePreview String?
  lastMessageAt      DateTime?
  afterHours         Boolean            @default(false)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser User?                 @relation("AssignedConversations", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages     ConversationMessage[]
  callSessions CallSession[]
  aiInteractions AIInteraction[]

  @@index([tenantId, lastMessageAt])
  @@index([tenantId, status, assignedUserId])
}

model ConversationMessage {
  id              String            @id @default(cuid())
  conversationId  String
  senderType      MessageSenderType @default(AGENT)
  senderUserId    String?
  parentMessageId String?
  body            String
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  conversation  Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser    User?                 @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  parentMessage ConversationMessage?  @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies       ConversationMessage[] @relation("MessageThread")
  reactions     MessageReaction[]
  receipts      MessageReceipt[]
  attachments   MessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
  @@index([parentMessageId, createdAt])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([userId, createdAt])
}

model MessageReceipt {
  id          String    @id @default(cuid())
  messageId   String
  userId      String
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  message ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt, createdAt])
}

model MessageAttachment {
  id          String   @id @default(cuid())
  messageId   String
  storageKey  String
  filename    String
  contentType String?
  sizeBytes   Int?
  createdAt   DateTime @default(now())

  message ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
}

model TenantInvitation {
  id              String           @id @default(cuid())
  tenantId        String
  roleId          String
  invitedByUserId String
  acceptedUserId  String?
  email           String
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  sentAt          DateTime?
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role          Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  invitedByUser User   @relation("SentInvitations", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedUser  User?  @relation("AcceptedInvitations", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, email, status])
  @@index([email, status, expiresAt])
}

model TenantApiKey {
  id              String    @id @default(cuid())
  tenantId        String
  createdByUserId String?
  name            String
  keyPrefix       String    @unique
  secretHash      String    @unique
  permissions     String[]
  lastUsedAt      DateTime?
  lastUsedIp      String?
  disabledAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser  User?  @relation("CreatedTenantApiKeys", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, disabledAt, createdAt])
  @@index([tenantId, name, createdAt])
}

model WebhookEndpoint {
  id              String                @id @default(cuid())
  tenantId        String
  url             String
  description     String?
  status          WebhookEndpointStatus @default(ACTIVE)
  signingSecret   String?
  eventTypes      String[]
  lastDeliveredAt DateTime?
  lastErrorAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId, status, createdAt])
}

model WebhookDelivery {
  id           String                @id @default(cuid())
  tenantId     String
  endpointId   String
  eventType    String
  status       WebhookDeliveryStatus @default(PENDING)
  statusCode   Int?
  requestId    String?
  responseBody String?
  payload      Json?
  durationMs   Int?
  attemptedAt  DateTime              @default(now())

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([tenantId, attemptedAt])
  @@index([endpointId, attemptedAt])
}

model BillingSubscription {
  id             String                    @id @default(cuid())
  tenantId       String                    @unique
  provider       String                    @default("manual")
  planKey        String                    @default("professional")
  planName       String                    @default("Professional")
  interval       BillingInterval           @default(MONTHLY)
  status         BillingSubscriptionStatus @default(ACTIVE)
  seatPriceCents Int                       @default(4900)
  currency       String                    @default("USD")
  activeSeats    Int                       @default(1)
  nextBillingAt  DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices BillingInvoice[]
}

model BillingInvoice {
  id             String               @id @default(cuid())
  tenantId       String
  subscriptionId String
  invoiceNumber  String               @unique
  status         BillingInvoiceStatus @default(PAID)
  amountCents    Int
  currency       String               @default("USD")
  issuedAt       DateTime
  periodStart    DateTime?
  periodEnd      DateTime?
  paidAt         DateTime?
  hostedUrl      String?
  createdAt      DateTime             @default(now())

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, issuedAt])
  @@index([subscriptionId, issuedAt])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  type      String
  title     String
  body      String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, readAt, createdAt])
}

model NotificationDevice {
  id          String                     @id @default(cuid())
  tenantId    String
  userId      String
  provider    NotificationDeviceProvider @default(FCM)
  platform    NotificationDevicePlatform @default(WEB)
  token       String                     @unique
  deviceLabel String?
  userAgent   String?
  lastSeenAt  DateTime                   @default(now())
  disabledAt  DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, disabledAt])
  @@index([tenantId, provider, platform])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, action, createdAt])
}

model AnalyticsEvent {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?
  eventName     String
  eventCategory String?
  value         Float?
  metadata      Json?
  occurredAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, occurredAt])
  @@index([tenantId, eventName, occurredAt])
}

model AIConfig {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  provider  String
  config    Json
  isEnabled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model ModerationReport {
  id             String           @id @default(cuid())
  tenantId       String
  reporterUserId String?
  targetType     String
  targetId       String
  reason         String
  status         ModerationStatus @default(OPEN)
  details        Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reporter User?  @relation("ReporterModerationReports", fields: [reporterUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
}

// ─── Phase 2: Groups / Channels ─────────────────────────────────────────────

enum ChannelType {
  PUBLIC
  PRIVATE
  DIRECT
}

model Channel {
  id              String      @id @default(cuid())
  tenantId        String
  name            String
  slug            String
  type            ChannelType @default(PUBLIC)
  description     String?
  topic           String?
  isArchived      Boolean     @default(false)
  createdByUserId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser  User?            @relation("ChannelCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  members        ChannelMember[]
  messages       ChannelMessage[]
  callSessions   CallSession[]
  aiInteractions AIInteraction[]

  @@unique([tenantId, slug])
  @@index([tenantId, isArchived, createdAt])
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model ChannelMessage {
  id              String   @id @default(cuid())
  channelId       String
  senderUserId    String?
  parentMessageId String?
  body            String
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  channel       Channel                  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderUser    User?                    @relation("ChannelMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  parentMessage ChannelMessage?          @relation("ChannelMessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies       ChannelMessage[]         @relation("ChannelMessageThread")
  reactions     ChannelMessageReaction[]

  @@index([channelId, createdAt])
}

model ChannelMessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

// ─── Phase 3: Calling ───────────────────────────────────────────────────────

enum CallStatus {
  RINGING
  ANSWERED
  BUSY
  FAILED
  ENDED
}

enum CallType {
  VOICE
  VIDEO
}

model CallSession {
  id                String     @id @default(cuid())
  tenantId          String
  conversationId    String?
  channelId         String?
  callType          CallType   @default(VOICE)
  status            CallStatus @default(RINGING)
  initiatedByUserId String?
  roomName          String?
  provider          String     @default("livekit")
  startedAt         DateTime   @default(now())
  answeredAt        DateTime?
  endedAt           DateTime?
  durationSeconds   Int?
  recordingUrl      String?
  metadata          Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation    Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  channel         Channel?          @relation(fields: [channelId], references: [id], onDelete: SetNull)
  initiatedByUser User?             @relation("InitiatedCalls", fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  participants    CallParticipant[]
  telemetry       CallTelemetry[]

  @@index([tenantId, status, createdAt])
  @@index([conversationId])
}

model CallParticipant {
  id            String    @id @default(cuid())
  callSessionId String
  userId        String
  joinedAt      DateTime  @default(now())
  leftAt        DateTime?
  isMuted       Boolean   @default(false)
  isOnHold      Boolean   @default(false)

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callSessionId, userId])
}

model CallTelemetry {
  id            String   @id @default(cuid())
  callSessionId String
  userId        String?
  eventName     String
  value         Float?
  metadata      Json?
  occurredAt    DateTime @default(now())

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([callSessionId, occurredAt])
}

// ─── Phase 4: Feed / Social ─────────────────────────────────────────────────

enum PostVisibility {
  PUBLIC
  TEAM
  PRIVATE
}

model Post {
  id           String         @id @default(cuid())
  tenantId     String
  authorUserId String
  body         String
  mediaUrls    String[]
  visibility   PostVisibility @default(TEAM)
  isPinned     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User           @relation("PostAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  comments  PostComment[]
  reactions PostReaction[]

  @@index([tenantId, visibility, createdAt])
}

model PostComment {
  id              String   @id @default(cuid())
  postId          String
  authorUserId    String
  parentCommentId String?
  body            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User          @relation("CommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  parentComment PostComment?  @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies       PostComment[] @relation("CommentThread")

  @@index([postId, createdAt])
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
}

// ─── Phase 5: Compliance ────────────────────────────────────────────────────

enum ComplianceExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ComplianceExport {
  id                String                 @id @default(cuid())
  tenantId          String
  requestedByUserId String?
  exportType        String
  status            ComplianceExportStatus @default(PENDING)
  storageKey        String?
  completedAt       DateTime?
  metadata          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedByUser User?  @relation("ComplianceRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
}

// ─── Phase 6: AI ────────────────────────────────────────────────────────────

enum AIInteractionType {
  CHATBOT
  ASSISTANT
  SUMMARIZATION
  MODERATION
  VOICE_BOT
}

model AIInteraction {
  id             String            @id @default(cuid())
  tenantId       String
  userId         String?
  type           AIInteractionType
  conversationId String?
  channelId      String?
  input          String
  output         String?
  model          String?
  provider       String?
  tokensUsed     Int?
  durationMs     Int?
  metadata       Json?
  createdAt      DateTime          @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([tenantId, type, createdAt])
}
