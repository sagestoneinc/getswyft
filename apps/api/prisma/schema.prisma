generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String         @id @default(uuid())
  name           String
  allowedOrigins String[]

  agents           Agent[]
  visitors         Visitor[]
  conversations    Conversation[]
  messages         Message[]
  routingSettings  RoutingSettings?
  webhookEndpoints WebhookEndpoint[]
}

model Agent {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[]

  @@unique([tenantId, email])
}

model Visitor {
  id       String  @id @default(uuid())
  tenantId String
  name     String?
  email    String?
  phone    String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, email])
}

model Conversation {
  id              String   @id @default(uuid())
  tenantId        String
  status          String   @default("open")
  assignedAgentId String?
  context         Json     @default("{}")
  createdAt       DateTime @default(now())
  source          String   @default("web")
  afterHours      Boolean  @default(false)
  leadName        String?
  leadEmail       String?
  leadPhone       String?

  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  assignedAgent Agent?    @relation(fields: [assignedAgentId], references: [id])
  messages      Message[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model Message {
  id             String   @id @default(uuid())
  tenantId       String
  conversationId String
  senderType     String
  senderId       String
  text           String?
  createdAt      DateTime @default(now())
  clientMsgId    String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, clientMsgId])
  @@index([conversationId, createdAt])
}

model RoutingSettings {
  id                  String  @id @default(uuid())
  tenantId            String  @unique
  mode                String  @default("first_available")
  timezone            String  @default("Asia/Manila")
  officeHours         Json    @default("{}")
  fallbackAgentId     String?
  lastAssignedAgentId String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model WebhookEndpoint {
  id       String  @id @default(uuid())
  tenantId String
  url      String
  secret   String?
  events   String[]
  isActive Boolean @default(true)

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  deliveries WebhookDelivery[]

  @@index([tenantId])
}

model WebhookDelivery {
  id               String   @id @default(uuid())
  endpointId       String
  eventType        String
  payload          Json
  status           String   @default("pending")
  attemptCount     Int      @default(0)
  lastResponseCode Int?
  nextRetryAt      DateTime?
  createdAt        DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([endpointId])
  @@index([status, nextRetryAt])
}
